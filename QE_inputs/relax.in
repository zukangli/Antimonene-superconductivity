&control
   calculation = 'vc-relax',
   prefix='pwscf',
   pseudo_dir ='/public/home/zkli/work/Tc/UPF_Tc'
   outdir='./',
   !tprnfor = .true.
   !tstress = .true.
   etot_conv_thr = 1.0d-5,
   forc_conv_thr = 1.0d-4,
/
&SYSTEM
    ibrav = 0,nat = 5,ntyp = 2,
   occupations='smearing',smearing='mp', degauss=0.02,
   ecutwfc=80.0,
   input_dft='vdw-df-obk8',
   assume_isolated='2D',
/
&electrons
   electron_maxstep = 1000
   mixing_beta = 0.3,
   conv_thr =  1.0d-12,
/
&ions
   ion_dynamics='bfgs',
/
&cell
   cell_dofree = 'all',
   cell_dynamics='bfgs',
   !press=200
/
ATOMIC_SPECIES
CELL_PARAMETERS {angstrom}
ATOMIC_POSITIONS (crystal)
K_POINTS {automatic}
36 36 1 0 0 0 
